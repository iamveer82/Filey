    "moduleNameMapper": {
      "^@react-native-async-storage/async-storage$": "<rootDir>/__tests__/__mocks__/asyncStorage.js",
      "^expo-file-system/legacy$": "<rootDir>/__tests__/__mocks__/stub.js",
      "^expo-sharing$": "<rootDir>/__tests__/__mocks__/stub.js",
      "^expo-document-picker$": "<rootDir>/__tests__/__mocks__/stub.js",
      "^expo-image-manipulator$": "<rootDir>/__tests__/__mocks__/stub.js",
      "^expo-calendar$": "<rootDir>/__tests__/__mocks__/stub.js",
      "^expo-secure-store$": "<rootDir>/__tests__/__mocks__/stub.js",
      "^expo-crypto$": "<rootDir>/__tests__/__mocks__/stub.js",
      "^react-native$": "<rootDir>/__tests__/__mocks__/stub.js",
      "^../services/llmProvider$": "<rootDir>/__tests__/__mocks__/stub.js",
      "^./llmProvider$": "<rootDir>/__tests__/__mocks__/stub.js",
      "^./webSearch$": "<rootDir>/__tests__/__mocks__/stub.js"
