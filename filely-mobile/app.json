{
  "expo": {
    "name": "Filely",
    "slug": "filely",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.filely.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Filely needs camera access to scan receipts",
        "NSPhotoLibraryUsageDescription": "Filely needs photo library access to upload receipts"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.filely.app"
    },
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      }
    }
  }
}
