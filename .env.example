# Filey environment file. Copy to `.env` and fill in only the values you need.
# Filey is offline-first — most of these are OPTIONAL.

# ─── Self-host (Docker / standalone) ─────────────────────────────────────────
# Port to expose Filey on the host.
FILEY_PORT=3000

# Public origin where the app is served (used for absolute share links).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# CORS allow-list. Default `*` is fine for personal self-host. Restrict for
# multi-tenant deployments (comma-separated origins).
CORS_ORIGINS=*

# ─── Optional: LLM defaults ──────────────────────────────────────────────────
# Users normally set their own BYOK key in Settings → AI Provider.
# These act as a server-side fallback. They are NEVER stored or logged —
# they pass through the /api/chat and /api/extract relays only.
# FILEY_DEFAULT_PROVIDER=anthropic
# FILEY_DEFAULT_MODEL=claude-sonnet-4-20250514
# FILEY_DEFAULT_API_KEY=

# ─── Optional: Supabase sync (Pro/Agency cross-device) ───────────────────────
# Used by the desktop/mobile apps that opt into encrypted cloud sync.
# Web-only self-host does NOT need these.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Optional: Mobile (Expo) ────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_API_URL=http://localhost:3000

# Cloudflare R2 CDN (mobile AI model download)
EXPO_PUBLIC_MODEL_CDN_URL=https://your-r2-bucket.cloudflareapp.com/gemma-4-E2B-it.litertlm

# ─── Optional: Cloudflare Workers AI (managed inference) ─────────────────────
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token
CF_AI_MODEL=@cf/google/gemma-4-26b-a4b-it
