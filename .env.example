# Supabase (server-side — Next.js web companion)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase (mobile — Expo app)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Cloudflare R2 CDN (for AI model download)
EXPO_PUBLIC_MODEL_CDN_URL=https://your-r2-bucket.cloudflareapp.com/gemma-4-E2B-it.litertlm

# Cloudflare Workers AI (server-side AI inference)
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token
CF_AI_MODEL=@cf/google/gemma-4-26b-a4b-it

# Mobile API endpoint (Next.js web companion URL)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Next.js web app
NEXT_PUBLIC_BASE_URL=http://localhost:3000
CORS_ORIGINS=*